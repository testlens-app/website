---
import Layout from "../layouts/Layout.astro";
import { title } from "../data/homepage.json";
---

<Layout pagetitle={title}>
  <div class="flex items-center justify-center">
    <div
      class="prose prose-slate w-full max-w-md rounded-lg bg-white p-6 shadow-lg"
    >
      <h2>Thank you for installing TestLens!</h2>
      <p>
        As a next step, please add the <a
          href="https://github.com/testlens-app/setup-testlens"
          target="_blank">setup-testlens</a
        > action to your GitHub Actions workflows.
      </p>
      <p>
        If you did not purchase a plan via GitHub Marketplace, please complete
        the form below so we can get in touch with you to complete the
        onboarding.
      </p>
      <form
        name="post-install-form"
        method="POST"
        netlify-honeypot="bot-field"
        data-netlify="true"
      >
        <input type="hidden" name="installation-id" />
        <p class="hidden">
          <label>
            Don’t fill this out if you’re human: <input name="bot-field" />
          </label>
        </p>
        <label class="mb-3 block">
          <span>Name</span>
          <input
            type="text"
            name="name"
            required
            class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-green-300 focus:ring focus:outline-none"
            placeholder="Contact name"
          />
        </label>
        <label class="mb-3 block">
          <span>Email</span>
          <input
            type="email"
            name="email"
            required
            class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-green-300 focus:ring focus:outline-none"
            placeholder="name@example.com"
          />
        </label>
        <div class="mt-6 flex justify-end gap-2">
          <button
            type="submit"
            class="cursor-pointer rounded bg-green-600 px-4 py-2 font-semibold text-white hover:bg-green-700"
          >
            Submit
          </button>
        </div>
      </form>
    </div>
  </div>
  <script>
    const urlSearchParams = new URLSearchParams(window.location.search);
    const params = Object.fromEntries(urlSearchParams.entries());
    document.forms["post-install-form"].elements["installation-id"].value =
      params["installation_id"];
  </script>
</Layout>
